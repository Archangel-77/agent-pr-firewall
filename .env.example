PORT=3000
LOG_LEVEL=info
GITHUB_API_BASE_URL=https://api.github.com
FIREWALL_PROTECTED_PATH_PREFIXES=.github/workflows/,infra/,terraform/,deploy/,ops/,production/
FIREWALL_MAX_CHANGED_FILES_WARN=25
FIREWALL_MAX_CHANGED_FILES_BLOCK=75
FIREWALL_MAX_CHANGED_LINES_WARN=800
FIREWALL_MAX_CHANGED_LINES_BLOCK=2000
GITHUB_APP_ID=123456
GITHUB_WEBHOOK_SECRET=replace-me
GITHUB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-your-private-key\n-----END PRIVATE KEY-----"
